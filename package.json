{
	"name": "subtle-toc",
	"version": "0.4.1",
	"description": "A floating, Capacities-style table of contents for Obsidian.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"table-of-contents",
		"toc",
		"outline"
	],
	"author": "xupisco",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.20.0",
		"obsidian": "latest",
		"tslib": "^2.6.2",
		"typescript": "^5.4.0"
	}
}
